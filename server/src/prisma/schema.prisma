datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ─── ENUMS ─────────────────────────────────────────────────────────────────────

enum UserRole {
  USER
  ADMIN
}

enum SubscriptionPlan {
  FREE
  PREMIUM
  PRO
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
}

enum DocumentType {
  SOP
  PERSONAL_STATEMENT
  CV
  RESEARCH_PROPOSAL
  SCHOLARSHIP_ESSAY
  EMAIL_PROFESSOR
}

enum DocumentStatus {
  DRAFT
  FINAL
}

// ─── MODELS ────────────────────────────────────────────────────────────────────

model User {
  id               String           @id @default(uuid()) @db.Uuid
  email            String           @unique
  password         String?
  authProvider     String           @default("local") // "local" | "google"
  fullName         String
  role             UserRole         @default(USER)
  subscriptionTier SubscriptionPlan @default(FREE)
  emailVerifiedAt  DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  // Relations
  profile       Profile?
  documents     Document[]
  aiGenerations AIGeneration[]
  subscription  Subscription?
  sessions      Session[]

  @@map("users")
}

model Profile {
  id                 String    @id @default(uuid()) @db.Uuid
  userId             String    @unique @db.Uuid
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  academicBackground String?   @db.Text
  achievements       Json? // Array of achievements (backward compatible)
  careerGoals        String?   @db.Text
  targetCountries    Json? // Array of strings
  targetFields       Json? // Array of strings
  
  // Personal
  dob                DateTime?
  nationality        String?

  // Education
  currentEducation   String?
  institution        String?
  gpa                String?
  graduationYear     Int?

  // Target Studies
  targetDegree       String?
  targetUniversities Json? // Array of target universities

  // Career
  dreamJob           String?

  // Experience, Projects, Volunteer & Skills
  workExperience     Json? // Array of experience details
  projects           Json? // Array of projects details
  awards             Json? // Array of awards details
  activities         Json? // Array of activity details
  volunteerWork      Json? // Array of volunteer details
  languages          Json? // Array of language competency details
  skills             Json? // Array of skills details
  englishTests       Json? // Array of english test records
  additionalNotes    String?   @db.Text

  // Soft delete indicator
  deletedAt          DateTime?

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@map("profiles")
}

model Document {
  id           String         @id @default(uuid()) @db.Uuid
  userId       String         @db.Uuid
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  documentType DocumentType
  status       DocumentStatus @default(DRAFT)
  content      Json? // Structured section-based document content
  deletedAt    DateTime? // Soft delete support
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  // Relations
  aiGenerations AIGeneration[]

  // Performance Indexes
  @@index([userId])
  @@index([documentType])
  @@index([createdAt])
  @@map("documents")
}

model AIGeneration {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @db.Uuid
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  documentId       String?   @db.Uuid
  document         Document? @relation(fields: [documentId], references: [id], onDelete: SetNull)
  prompt           String    @db.Text
  response         String    @db.Text
  tokensUsed       Int?      // Total tokens
  provider         String?   // "openai" | "anthropic" | "gemini"
  modelUsed        String?   // e.g. "gpt-4o", "claude-3-5-sonnet"
  
  // Auditing details
  requestId        String?   // correlation request ID
  promptTokens     Int?      // estimated prompt tokens
  completionTokens Int?      // estimated completion tokens
  latency          Int?      // call latency in milliseconds

  createdAt        DateTime  @default(now())

  // Performance Indexes
  @@index([userId])
  @@index([createdAt])
  @@map("ai_generations")
}

model Subscription {
  id                     String             @id @default(uuid()) @db.Uuid
  userId                 String             @unique @db.Uuid
  user                   User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan                   SubscriptionPlan   @default(FREE)
  status                 SubscriptionStatus @default(ACTIVE)
  billingProvider        String             @default("stripe")
  stripeCustomerId       String?            @unique
  stripeSubscriptionId   String?            @unique
  currentPeriodEnd       DateTime?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  // Implicitly indexed via unique constraint on userId, but explicit indexing matches SDD
  @@index([userId])
  @@map("subscriptions")
}

model Session {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @db.Uuid
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  // bcrypt hash of the raw refresh token — the plain token is NEVER stored
  refreshTokenHash String
  // Browser/client identifier forwarded from the User-Agent header
  userAgent        String?   @db.Text
  // IP address of the client that created the session, used for anomaly detection
  ipAddress        String?
  // Hard expiry timestamp — session is invalid after this point even if not revoked
  expiresAt        DateTime
  // Set on logout or on refresh-token reuse detection (token theft signal)
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Fast lookup by userId (most common query: "list all active sessions for user")
  @@index([userId])
  // Fast lookup on token refresh path: fetch session by id + check revocation
  @@index([expiresAt])
  @@map("sessions")
}
